#!/usr/bin/env bash
# spider-server — multi-session connection manager CLI
set -uo pipefail

if [[ -n "${SPIDER_ROOT:-}" && -d "${SPIDER_ROOT}/lib/server" ]]; then
  ROOT="$SPIDER_ROOT"
elif [[ -n "${SPIDER_LIBDIR:-}" && -d "${SPIDER_LIBDIR}/server" ]]; then
  ROOT="$(cd "${SPIDER_LIBDIR}/.." && pwd)"
else
  ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
fi

MANAGER="${ROOT}/lib/server/manager.py"
if [[ ! -f "$MANAGER" ]]; then
  echo "spider-server: missing ${MANAGER}" >&2
  exit 1
fi

exec /usr/bin/env python3 "$MANAGER" "$@"
